# Stripe Publishable Key (for frontend payment processing)
# Get your key from: https://dashboard.stripe.com/test/apikeys
# This should start with pk_test_ for test mode
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"

# Google Maps API Key (for maps and Places autocomplete)
# Get your key from: https://console.cloud.google.com/
# Enable: Maps SDK for iOS, Maps SDK for Android, Places API, Geocoding API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyDJJ1acllPA41MzxJenjIpY-C7H1BnOQ5k"

# API Base URL (optional, defaults to localhost in development)
# EXPO_PUBLIC_API_URL="http://localhost:3001/api"

# Public web origin used for canonical URLs, sitemap generation, and OpenGraph defaults
# EXPO_PUBLIC_WEB_URL="https://buildmyhouse.app"

# Google Search Console domain verification token
# EXPO_PUBLIC_GSC_VERIFICATION=""

# GA4 Measurement ID for web analytics (format: G-XXXXXXXXXX)
# EXPO_PUBLIC_GA_MEASUREMENT_ID=""

# Google Sign-In — **Web application** OAuth client ID (same as backend GOOGLE_CLIENT_ID for code exchange)
# EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Optional web-only: EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
# Optional exact redirect: EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=
