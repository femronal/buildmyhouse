# API (include /api suffix to match app code)
EXPO_PUBLIC_API_URL=https://api.buildmyhouse.app/api

# Google Sign-In — use the **Web application** OAuth client ID from Google Cloud (same as backend GOOGLE_CLIENT_ID).
# Must be present at `expo export` / EAS build time (not only on the server).
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Web-only client ID if native builds use a different Google client
# EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# Optional: override redirect URI (must match Google Console exactly, e.g. https://gc.buildmyhouse.app/)
# EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=
