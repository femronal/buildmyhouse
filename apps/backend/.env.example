# Database
DATABASE_URL="postgresql://user:password@localhost:5432/buildmyhouse?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Stripe Payment Processing
# Get your keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# OpenAI API (for plan analysis)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your_openai_api_key_here"

# Google OAuth (for authentication)
# Get your credentials from: https://console.cloud.google.com/apis/credentials
# For Expo apps using POST /auth/google/mobile, use the same **Web application** client ID + secret
# as EXPO_PUBLIC_GOOGLE_CLIENT_ID in the mobile/web frontends (token exchange requires matching client).
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"
# Web static sites (e.g. https://gc.buildmyhouse.app/): add that exact URL under the Web client's
# "Authorized redirect URIs" and the origin under "Authorized JavaScript origins".

# S3 uploads (recommended for ECS/production)
# Uploads are persisted to S3 instead of ephemeral container storage.
AWS_REGION="eu-north-1"
AWS_S3_BUCKET="buildmyhouse-prod-uploads"
# Optional path prefix inside the bucket (defaults to "uploads")
AWS_S3_UPLOADS_PREFIX="uploads"
# Optional CloudFront/custom domain for public file URLs
# Example: https://assets.buildmyhouse.app
AWS_S3_PUBLIC_BASE_URL=""

# CORS (comma-separated list of allowed origins)
# For production, include your web app URLs:
# ALLOWED_ORIGINS="https://app.buildmyhouse.app,https://gc.buildmyhouse.app,https://admin.buildmyhouse.app"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8081"

# Server Port (optional, defaults to 3001)
PORT=3001

# Email notifications (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_your_resend_api_key_here"
# Optional aliases also supported by the backend:
# RESEND_API_TOKEN="re_your_resend_api_key_here"
# RESEND_KEY="re_your_resend_api_key_here"
# RESEND_TOKEN="re_your_resend_api_key_here"
# Sender email. For testing, use "onboarding@resend.dev" (sends only to your signup email).
# For production, verify your domain at https://resend.com/domains and use e.g. "BuildMyHouse <notifications@yourdomain.com>"
EMAIL_FROM="BuildMyHouse <onboarding@resend.dev>"
