{
  "family": "buildmyhouse-admin",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::399095821429:role/ecsTaskExecutionRole-buildmyhouse",
  "taskRoleArn": "arn:aws:iam::399095821429:role/ecsTaskExecutionRole-buildmyhouse",
  "containerDefinitions": [
    {
      "name": "admin",
      "image": "399095821429.dkr.ecr.eu-north-1.amazonaws.com/buildmyhouse-admin:latest",
      "essential": true,
      "command": [],
      "portMappings": [{ "containerPort": 3000 }],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/buildmyhouse-admin",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3000/health',r=>{r.resume();process.exit(r.statusCode>=200&&r.statusCode<400?0:1)}).on('error',()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 90
      }
    }
  ]
}
