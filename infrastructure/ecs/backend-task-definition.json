{
  "family": "buildmyhouse-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::399095821429:role/ecsTaskExecutionRole-buildmyhouse",
  "taskRoleArn": "arn:aws:iam::399095821429:role/ecsTaskExecutionRole-buildmyhouse",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "399095821429.dkr.ecr.eu-north-1.amazonaws.com/buildmyhouse-backend:latest",
      "essential": true,
      "command": ["sh", "-c", "pnpm prisma:generate && npx prisma migrate deploy && node dist/src/main.js"],
      "portMappings": [{ "containerPort": 3001 }],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "3001" },
        { "name": "GOOGLE_CALLBACK_URL", "value": "https://api.buildmyhouse.app/api/auth/google/callback" },
        { "name": "ALLOWED_ORIGINS", "value": "https://admin.buildmyhouse.app,https://buildmyhouse.app,https://gc.buildmyhouse.app,http://localhost:3000,http://localhost:8081,http://localhost:1990,http://localhost:3988" },
        { "name": "AWS_REGION", "value": "eu-north-1" },
        { "name": "AWS_S3_UPLOADS_PREFIX", "value": "uploads" },
        { "name": "AWS_S3_PUBLIC_BASE_URL", "value": "" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/database-url" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/jwt-secret" },
        { "name": "GOOGLE_CLIENT_ID", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/google-client-id" },
        { "name": "GOOGLE_CLIENT_SECRET", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/google-client-secret" },
        { "name": "AWS_S3_BUCKET", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/s3-bucket" },
        { "name": "RESEND_API_KEY", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/resend-api-key" },
        { "name": "EMAIL_FROM", "valueFrom": "arn:aws:ssm:eu-north-1:399095821429:parameter/buildmyhouse/production/email-from" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/buildmyhouse-backend",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"require('http').get('http://localhost:3001/api/health',r=>{r.resume();process.exit(r.statusCode>=200&&r.statusCode<400?0:1)}).on('error',()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 120
      }
    }
  ]
}
